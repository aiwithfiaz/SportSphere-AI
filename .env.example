# ===========================================
# SportSphere AI - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# Application
# ===========================================
NODE_ENV=development
APP_NAME=sportsphere-ai
APP_PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportsphere_ai
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sportsphere_ai
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# Authentication
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_REFRESH_EXPIRES_IN=30d

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-this

# ===========================================
# AI/ML Services
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-org-id
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Hugging Face (for sports-specific models)
HUGGINGFACE_API_KEY=hf_your-huggingface-api-key

# ===========================================
# Sports Data APIs
# ===========================================
ESPN_API_KEY=your-espn-api-key
SPORTS_DATA_API_KEY=your-sports-data-api-key
ODDS_API_KEY=your-odds-api-key
WEATHER_API_KEY=your-weather-api-key

# ===========================================
# Cloud Services (AWS)
# ===========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=sportsphere-ai-assets

# ===========================================
# Monitoring & Observability
# ===========================================
SENTRY_DSN=https://your-sentry-dsn
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Email (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@sportsphere.ai

# ===========================================
# Search (Meilisearch / Elasticsearch)
# ===========================================
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-api-key
ELASTICSEARCH_URL=http://localhost:9200

# ===========================================
# Feature Flags
# ===========================================
ENABLE_AI_PREDICTIONS=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_ADVANCED_ANALYTICS=true

# ===========================================
# Development Tools
# ===========================================
# Uncomment for debugging
# DEBUG=sportsphere:*
# NODE_OPTIONS=--inspect
